{
  "name": "@peoplevault/api-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "gen": "openapi-typescript ../../openapi/openapi.yaml -o src/generated/schema.d.ts",
    "build": "tsc -p tsconfig.json && node ./scripts/copy-generated.mjs",
    "clean": "rm -rf dist src/generated"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.5.0",
    "typescript": "^5.6.0"
  }
}

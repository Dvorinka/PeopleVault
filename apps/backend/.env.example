# PeopleVault environment variables. Copy to .env and adjust.
# NEVER commit real secrets.

# --- App ---
APP_ENV=development
APP_PORT=8081
APP_LOG_LEVEL=info
APP_PUBLIC_URL=http://localhost:8080

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=peoplevault
POSTGRES_PASSWORD=peoplevault_dev
POSTGRES_DB=peoplevault
DATABASE_URL=postgres://peoplevault:peoplevault_dev@localhost:5432/peoplevault?sslmode=disable

# --- DragonflyDB (Redis-compatible cache) — OPTIONAL ---
# Leave empty to run without cache. Backend works cache-free by default.
DRAGONFLY_ADDR=
DRAGONFLY_PASSWORD=

# --- Auth (Better Auth) ---
AUTH_SECRET=change-me-to-a-32-byte-random-string
AUTH_SESSION_COOKIE=peoplevault_session
AUTH_SESSION_TTL=2592000
AUTH_REMEMBER_ME_TTL=7776000
AUTH_RATE_LIMIT_PER_MIN=10

# --- CORS / CSRF ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8081
VITE_APP_NAME=PeopleVault
